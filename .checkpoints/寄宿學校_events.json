              "type": "sanity",
              "value": -15
            },
            {
              "type": "location",
              "value": "corridor"
            }
          ]
        }
      ],
      "once": true
    },
    {
      "id": "event_night_rollcall",
      "title": "夜間點名",
      "trigger": "凌晨舍監進入 dorm_room 點名",
      "description": "手電筒光掃過每張床。舍監念著名字，聲音平板。輪到你時，他念的姓名只差一個字——卻又像在等你答「有」。",
      "choices": [
        {
          "id": "answer_yes",
          "label": "清楚答「有」",
          "resultText": "你應聲。舍監在簿上劃去你，光熄了。",
          "effects": [
            {
              "type": "flag",
              "key": "answeredRollcall",
              "value": true
            },
            {
              "type": "anomaly",
              "value": 2
            }
