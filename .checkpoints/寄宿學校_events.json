        },
        {
          "id": "stay_silent",
          "label": "屏息，不出聲",
          "resultText": "他停頓良久，記下「缺席」，繼續往下一床。",
          "effects": [
            {
              "type": "flag",
              "key": "neverAnswered",
              "value": true
            },
            {
              "type": "sanity",
              "value": -10
            },
            {
              "type": "sheet",
              "value": "doc_burnt_register_page"
            }
          ]
        }
