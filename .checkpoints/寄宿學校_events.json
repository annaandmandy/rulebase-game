{
  "events": [
    {
      "id": "event_intro_dorm_arrival",
      "title": "夜讀生報到",
      "trigger": "玩家首次進入 dorm_room",
      "description": "你被分配到靠窗的空床。枕邊壓著一張《夜間住宿須知》，墨色很新。對床的棉被鼓起，像有人蓋著，卻沒有呼吸聲。",
      "choices": [
        {
          "id": "read_rules",
          "label": "讀完須知並收好",
          "resultText": "你記下八條規則。熄燈廣播在窗外響起。",
          "effects": [
            {
              "type": "sheet",
              "value": "doc_official_dorm_guide"
            },
            {
              "type": "flag",
              "key": "readDormGuide",
              "value": true
            }
          ]
        },
        {
          "id": "check_bed",
          "label": "掀開對床的棉被看看",
          "resultText": "棉被下是疊好的舊衣，名牌被撕去。你背脊發涼。",
          "effects": [
            {
              "type": "sheet",
              "value": "doc_official_dorm_guide"
            },
            {
              "type": "sanity",
              "value": -15
            },
            {
              "type": "anomaly",
              "value": 2
            }
          ]
        }
      ],
      "once": true
    },
    {
