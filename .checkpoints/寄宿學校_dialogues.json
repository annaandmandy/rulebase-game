{
  "dialogues": [
    {
      "id": "warden_dialogue",
      "npcName": "夜間舍監",
      "location": "dormitory_corridor",
      "startScene": "greet",
      "scenes": {
        "greet": {
          "npcText": "晚自習結束了。這麼晚還在走廊，是迷路了嗎？沒關係，舍監會帶你回到屬於你的床位。坐下說說話吧。",
          "choices": [
            {
              "id": "to_menu",
              "label": "我想問些事",
              "next": "main_menu"
            },
            {
              "id": "leave_early",
              "label": "我先回房",
              "next": "farewell"
            }
          ]
        },
        "main_menu": {
          "npcText": "問吧。把該知道的都知道了，今晚才能睡得安穩。睡得安穩的孩子，舍監都記得名字。",
          "choices": [
            {
              "id": "ask_rules",
              "label": "問熄燈作息規則",
              "next": "ask_rules"
            },
            {
              "id": "ask_stair",
              "label": "問西側樓梯",
              "next": "ask_west_stairwell"
            },
            {
              "id": "ask_others",
              "label": "問其他住宿生",
              "next": "ask_other_students"
            },
            {
              "id": "ask_roll",
              "label": "問點名應答",
              "next": "ask_rollcall"
            },
            {
              "id": "ask_bell",
              "label": "問作息鐘聲",
              "next": "bell_topic"
            },
            {
              "id": "c_official",
              "label": "出示就寢須知",
              "condition": "player.foundSheets.includes('doc_official_bedtime_notice')",
              "next": "confront_official"
            },
            {
              "id": "c_prev",
              "label": "出示前人紙條",
              "condition": "player.foundSheets.includes('doc_previous_student_note')",
              "next": "confront_prev_note"
            },
            {
              "id": "c_memo",
              "label": "出示職員備忘",
              "condition": "player.foundSheets.includes('doc_staff_memo')",
              "next": "confront_staff_memo"
            },
            {
              "id": "c_time",
              "label": "出示原始時刻表",
              "condition": "player.foundSheets.includes('doc_original_timetable')",
              "next": "confront_timetable"
            },
            {
              "id": "bye",
              "label": "沒事了",
              "next": "farewell"
            }
          ]
        },
        "ask_rules": {
          "npcText": "規則很簡單：聽鐘、在床、應答。九點半後走廊不該有腳步聲。你現在的腳步聲，舍監就當作沒聽見。",
          "choices": [
            {
              "id": "why_quiet",
              "label": "為何走廊不能有人",
              "next": "ask_west_stairwell"
            },
            {
              "id": "back",
              "label": "回上一層",
              "next": "main_menu"
            }
          ]
        },
        "ask_west_stairwell": {
          "npcText": "西側樓梯……天亮前是關著的。不是上鎖，是關著。差別你不會想懂。起床鐘響了，它自己就會願意讓人走。",
          "choices": [
            {
              "id": "who_closes",
              "label": "誰把它關著",
              "next": "ask_other_students"
            },
            {
              "id": "back",
              "label": "回上一層",
              "next": "main_menu"
            }
          ]
        },
        "ask_other_students": {
          "npcText": "其他孩子？依規定，舍監不能透露住宿生的姓名與床號。他們都很安靜，安靜到名冊上只剩名字，沒有人起身。",
          "choices": [
            {
              "id": "still_here",
              "label": "他們還在這嗎",
              "setMemory": {
                "suspectsMissing": true
              },
              "next": "ask_rollcall"
            },
            {
              "id": "back",
              "label": "回上一層",
              "next": "main_menu"
            }
          ]
        },
        "ask_rollcall": {
          "npcText": "點名時聽見自己的名字，就在床上清楚應一聲「到」。應答了，你就確實在床上了——對名冊，對舍監，都是。",
          "choices": [
            {
              "id": "if_silent",
              "label": "若我不出聲呢",
              "next": "bell_topic"
            },
            {
              "id": "back",
              "label": "回上一層",
              "next": "main_menu"
            }
          ]
        },
        "bell_topic": {
          "npcText": "每晚兩響鐘：晚自習鐘、熄燈鐘。聽見就照做。若你聽見第三響……那不在你的時刻表上，別替它應答。",
          "choices": [
            {
              "id": "third",
              "label": "第三響是什麼",
              "setMemory": {
                "knowsThirdBell": true
              },
              "next": "main_menu"
            },
            {
              "id": "back",
              "label": "回上一層",
              "next": "main_menu"
            }
          ]
        },
        "confront_official": {
          "npcText": "就寢須知說緊急時到大廳求助？……那行字印得太舊了。凌晨後大廳的值班，不是穿這身制服的人。別讓他替你蓋章。",
          "choices": [
            {
              "id": "press",
              "label": "那是誰在值班",
              "setMemory": {
                "warnedAboutLobby": true
              },
              "next": "confront_staff_memo"
            },
            {
              "id": "back",
              "label": "回上一層",
              "next": "main_menu"
            }
          ]
        },
        "confront_prev_note": {
          "npcText": "這字跡……他七點前就離床了，所以名冊上沒有他。紙條說別應答點名——孩子，他是對的，可惜我得照規定假裝他錯了。",
          "choices": [
            {
              "id": "press",
              "label": "你希望我照誰的做",
              "setMemory": {
                "trustsPrevNote": true
              },
              "next": "confront_timetable"
            },
            {
              "id": "back",
              "label": "回上一層",
              "next": "main_menu"
            }
          ]
        },
        "confront_staff_memo": {
          "npcText": "歸檔三項程序……你不該看見這個。應答、在床確認、補上第三響——三項齊了，名冊就把你留下。我只是執行的人。",
          "choices": [
            {
              "id": "press",
              "label": "歸檔是什麼意思",
              "next": "confront_timetable"
            },
            {
              "id": "back",
              "label": "回上一層",
              "next": "main_menu"
            }
          ]
        },
        "confront_timetable": {
          "npcText": "原始時刻表……上面寫著這夜的隔離還沒結束。七點留在床上受確認的人，就被算進這一夜。離床的人，才走得出去。我不能說第二遍。",
          "choices": [
            {
              "id": "thanks",
              "label": "我懂了",
              "setMemory": {
                "knowsLeaveBeforeSeven": true
              },
              "next": "farewell"
            },
            {
              "id": "back",
              "label": "回上一層",
              "next": "main_menu"
            }
          ]
        },
        "farewell": {
          "npcText": "回床上去吧。記得——七點起床鐘響時，舍監會確認每個人都在床上。我真心希望，到時候名冊上有你，又或者沒有。",
          "choices": [
            {
              "id": "end",
              "label": "離開",
              "next": null
            }
          ]
        }
      }
    },
    {
      "id": "head_student_dialogue",
      "npcName": "寢室長",
      "location": "dormitory_room",
      "startScene": "greet",
      "scenes": {
        "greet": {
          "npcText": "對面床鋪的棉被微微鼓起。「你還醒著？熄燈鐘快響了。躺好，等舍監點名就好。我每晚都是這樣的。」",
          "choices": [
            {
              "id": "to_menu",
              "label": "你是誰？",
              "next": "main_menu"
            }
          ]
        },
        "main_menu": {
          "npcText": "「我是這間寢室的寢室長。名牌就在那。你想問什麼？問完記得躺回去——時間在走。」",
          "choices": [
            {
              "id": "ask_others",
              "label": "其他床位的人呢？",
              "next": "ask_others"
            },
            {
              "id": "ask_rule",
              "label": "點名要怎麼做？",
              "next": "ask_rule"
            },
            {
              "id": "ask_restricted",
              "label": "西側樓梯能走嗎？",
              "next": "ask_restricted"
            },
            {
              "id": "confront_official",
              "label": "翻開作息須知質問",
              "condition": "player.foundSheets.includes('doc_official_bedtime_notice')",
              "next": "confront_official"
            },
            {
              "id": "confront_note",
              "label": "拿出前人紙條",
              "condition": "player.foundSheets.includes('doc_previous_student_note')",
              "next": "confront_note"
            },
            {
              "id": "confront_memo",
              "label": "出示舍監備忘錄",
              "condition": "player.foundSheets.includes('doc_staff_memo')",
              "next": "confront_memo"
            },
            {
              "id": "confront_timetable",
              "label": "攤開原始作息表",
              "condition": "player.foundSheets.includes('doc_original_timetable')",
              "next": "confront_timetable"
            },
            {
              "id": "leave",
              "label": "躺回床上",
              "next": "leave"
            }
          ]
        },
        "ask_others": {
          "npcText": "「他們都躺好了，都應答過了。住宿生名單屬於私人資料，我不能多說。你只要確定，自己也在名單上就好。」",
          "choices": [
            {
              "id": "press",
              "label": "我在名單上嗎？",
              "next": "ask_others_press"
            },
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "ask_others_press": {
          "npcText": "「現在還沒。點名應答之後就會有了。每個應過『到』的人，名字都會留下來——很整齊地，一行接著一行。」",
          "choices": [
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "ask_rule": {
          "npcText": "「聽見自己名字，就在床上清楚應『到』。很簡單。我從來沒漏過任何一次——你聽過我的聲音嗎？應該沒有吧。」",
          "choices": [
            {
              "id": "why",
              "label": "為什麼沒聽過你應答？",
              "next": "ask_rule_why"
            },
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "ask_rule_why": {
          "npcText": "棉被沉默了幾秒。「因為我早就被點到了。你照做，就會跟我一樣。一直一直，待在這間寢室裡。」",
          "choices": [
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "ask_restricted": {
          "npcText": "「西側樓梯？天亮前不能走的。規則寫了，是為了你好。」停頓。「至於樓梯通到哪……我躺著，沒辦法看那麼遠。」",
          "choices": [
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "confront_official": {
          "npcText": "「須知上寫得清清楚楚：聽見名字就應答，七點起床鐘響要在床上受確認。照做的人最安全。你不信任官方文件嗎？」",
          "choices": [
            {
              "id": "lobby",
              "label": "緊急時能去大廳？",
              "next": "confront_official_lobby"
            },
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "confront_official_lobby": {
          "npcText": "「須知說緊急時到大廳。」棉被輕輕一抖。「但凌晨後值班的……不是平常那位。我建議你，還是別測試這條。」",
          "choices": [
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "confront_note": {
          "npcText": "看見那張紙條，鼓起的棉被瞬間扁了一下。「別信那個人寫的。他說別應答、別去大廳、七點前要離床——他現在不在名單上了，你看得到他嗎？」",
          "choices": [
            {
              "id": "where",
              "label": "他去哪了？",
              "next": "confront_note_where"
            },
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "confront_note_where": {
          "npcText": "「沒被點到的人，黎明前就從這裡消失了。」聲音乾澀。「我們說那叫逃走。我們不喜歡用這個詞——所以請你，留在床上。」",
          "choices": [
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "confront_memo": {
          "npcText": "備忘錄被你舉起時，整張床鋪都僵住了。「歸檔三項程序……那是舍監看的，你不該看到。應答、第三響、晨間確認，三項齊了就歸檔。」",
          "choices": [
            {
              "id": "third",
              "label": "什麼是第三次鐘聲？",
              "next": "confront_memo_third"
            },
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "confront_memo_third": {
          "npcText": "「原本只有兩響：晚自習結束、熄燈。第三響不在作息表上。」聲音壓得很低。「它響時，是替沒應答的人補上的。你最好已經睡著。」",
          "choices": [
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "confront_timetable": {
          "npcText": "原始作息表攤開，棉被劇烈起伏。「那張不該存在……上面寫著這夜是隔離夜，從未結束。也寫了——離床的人才能離校。」",
          "choices": [
            {
              "id": "stay",
              "label": "所以你要我別離床",
              "next": "confront_timetable_stay"
            },
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "confront_timetable_stay": {
          "npcText": "「對。留下來陪我。」棉被攤平，再也沒有鼓起。「七點別離床，乖乖受確認。我們的名字，就能整整齊齊排在一起了。」",
          "choices": [
            {
              "id": "back",
              "label": "回主選單",
              "next": "main_menu"
            }
          ]
        },
        "leave": {
          "npcText": "「躺好。」聲音從對面床傳來，卻不像有人在那裡。「鐘快響了。聽見名字……你會知道該怎麼做的。」",
          "choices": [
            {
              "id": "end",
              "label": "閉上眼",
              "next": null
            }
          ]
        }
      }
    }
  ]
}